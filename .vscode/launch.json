{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Local Viewer Mock Stack (F5)",
            "type": "node-terminal",
            "request": "launch",
            "command": "bash ${workspaceFolder}/dev/start-local.sh",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Frontend: (http://127\\.0\\.0\\.1:8088/webhookviewer\\.php)",
                "uriFormat": "%s"
            }
        },
        {
            // Passiver Listener: Xdebug verbindet sich von außen (Server läuft bereits)
            "name": "Listen for Xdebug",
            "type": "php",
            "request": "launch",
            "port": 9003,
            "pathMappings": {
                "/Users/openclaw/dev/openrouter-webhook-logger": "${workspaceFolder}"
            }
        },
        {
            // Startet PHP Built-in Server + wartet auf Xdebug-Verbindung
            "name": "Webhook Server (localhost:8080)",
            "type": "php",
            "request": "launch",
            "runtimeArgs": [
                "-S", "localhost:8080",
                "-t", "${workspaceFolder}/public"
            ],
            "port": 9003,
            "cwd": "${workspaceFolder}",
            "env": {
                "XDEBUG_MODE": "debug",
                "XDEBUG_SESSION": "1"
            },
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Development Server \\(http://localhost:8080\\) started"
            }
        }
    ],
    "compounds": [
        {
            "name": "F5 Local Mock Stack",
            "configurations": [
                "Local Viewer Mock Stack (F5)"
            ]
        }
    ]
}
