Options -MultiViews
RewriteEngine On
RewriteBase /

# Pass Authorization header through to PHP (stripped by Apache on shared hosting)
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# Dashboard: /webhookviewer and /webhookviewer/ → webhookviewer.php
RewriteRule webhookviewer webhookviewer.php [L,QSA]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]

